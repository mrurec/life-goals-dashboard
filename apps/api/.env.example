# Copy this file to .env and fill in values for local development.
# .env is gitignored — never commit secrets.

# PostgreSQL
POSTGRES_DB=lifegoals
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me

# Redis (no auth required for local dev)

# Backend
DB_URL=jdbc:postgresql://localhost:5432/lifegoals
DB_USERNAME=postgres
DB_PASSWORD=change_me
REDIS_URL=redis://localhost:6379
JWT_SECRET=change_me_256_bit_secret_here
OAUTH_CLIENT_ID=change_me
OAUTH_CLIENT_SECRET=change_me
EXCHANGE_RATE_API_KEY=change_me
EXCHANGE_RATE_API_URL=https://api.exchangeratesapi.io/v1/latest
FEATURE_FLAGS_PATH=config/features.json
