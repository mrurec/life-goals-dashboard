# VCS & IDE artefacts
.git
.gitignore
.idea
*.iml
.DS_Store
.editorconfig
.omc

# Gradle cache and previous build output (not needed inside the Docker build
# context; the builder stage runs ./gradlew from scratch inside the image)
.gradle
build

# Secrets — never bake into the image
.env
*.env
**/*.env

# Dev-only tooling not needed in the image
docker-compose.yml
Dockerfile
.dockerignore
HELP.md
