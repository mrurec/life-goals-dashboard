# Normalize line endings to LF on commit (cross-platform safety)
* text=auto eol=lf

# Kotlin / JVM sources
*.kt    text eol=lf
*.kts   text eol=lf
*.java  text eol=lf

# Frontend sources
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.css   text eol=lf

# Config / schema files
*.graphqls  text eol=lf
*.sql       text eol=lf
*.json      text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.toml      text eol=lf
*.xml       text eol=lf
*.md        text eol=lf
*.sh        text eol=lf

# Gradle wrapper — keep as-is
gradlew     text eol=lf
gradlew.bat text eol=crlf

# Binary files — no line ending conversion
*.jar   binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
